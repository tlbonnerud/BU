# BedriftUtility — production env template.
# Copy to .env.production (gitignored) and fill in. Deploy with:
#   docker compose --env-file .env.production up -d --build
#
# Auth is OUR OWN: access/refresh tokens in cookies, sessions in Redis, own role
# checks. Supabase = Postgres database only (browse tables in Supabase Studio).

# ── Database (Supabase Postgres, used as a plain DB) ──────────────────────────
DATABASE_URL=postgresql://postgres:<password>@hjemmeserver:5434/postgres
DATABASE_URL_TX=postgresql://postgres:<password>@hjemmeserver:6544/postgres
# Internal alternative (if the app joins the Supabase Docker network):
#   postgresql://postgres:<password>@bedriftutility-db:5432/postgres

# ── Redis (session + refresh-token store) ─────────────────────────────────────
# REDIS_URL is set in docker-compose.yml (redis://redis:6379). Optional password:
# REDIS_PASSWORD=<generate-long-random>

# ── App auth (your own tokens) ────────────────────────────────────────────────
AUTH_SECRET=<generate: openssl rand -base64 48>
ACCESS_TOKEN_TTL=900          # 15 min
REFRESH_TOKEN_TTL=1209600     # 14 days

# ── Supabase REST (OPTIONAL — only if you query via supabase-js server-side) ──
# SUPABASE_URL=http://bedriftutility-kong:8000
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Supabase Docker network (Postgres access by container name) ───────────────
# docker inspect bedriftutility-kong -f '{{json .NetworkSettings.Networks}}'
SUPABASE_NETWORK=supabase_default

# ── Cloudflare Tunnel ─────────────────────────────────────────────────────────
TUNNEL_TOKEN=<cloudflare-tunnel-token>

# ── GitHub webhook ────────────────────────────────────────────────────────────
WEBHOOK_SECRET=<long-random-secret>
